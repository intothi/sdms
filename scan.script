#!/bin/bash
# ============================================================
# SDMS Scan Script
# Wird von scanbd beim Drücken des Scan-Knopfs ausgeführt
# ============================================================
exec > /tmp/sdms_scan.log 2>&1

BACKEND="http://localhost:8080/v1/document/post"
TMPDIR="/tmp/sdms_scan"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
PDF_FINAL="$TMPDIR/scan_$TIMESTAMP"  # tesseract fügt .pdf selbst an

mkdir -p $TMPDIR

# ── Lock-File ─────────────────────────────────────────────────
LOCKFILE="/tmp/sdms_scan.lock"
if [ -f "$LOCKFILE" ]; then
    echo "Scan läuft bereits, abbrechen"
    exit 0
fi
curl -s -X POST http://localhost:8080/v1/scan/start
touch $LOCKFILE
trap "rm -f $LOCKFILE" EXIT

echo "SDMS Scan gestartet: $TIMESTAMP"

# ── 0. Scanner Konfiguration laden ───────────────────────────
CONFIG=$(curl -s http://localhost:8080/v1/scannerConfig)
if [ -z "$CONFIG" ]; then
    echo "Fehler beim Laden der Scanner-Konfiguration – nutze Standardwerte"
    RESOLUTION=300
    COLOR_MODE="Gray"
    SCAN_MODE="ADF Duplex"
    SWSKIP=15
    PAGE_WIDTH=210
    PAGE_HEIGHT=297
else
    RESOLUTION=$(echo $CONFIG  | jq -r '.resolution')
    COLOR_MODE=$(echo $CONFIG  | jq -r '.colorMode')
    SCAN_MODE=$(echo $CONFIG   | jq -r '.scanMode')
    SWSKIP=$(echo $CONFIG      | jq -r '.swSkip')
    PAGE_WIDTH=$(echo $CONFIG  | jq -r '.pageWidth')
    PAGE_HEIGHT=$(echo $CONFIG | jq -r '.pageHeight')
fi

echo "Konfiguration: resolution=$RESOLUTION colorMode=$COLOR_MODE scanMode=$SCAN_MODE swSkip=$SWSKIP pageWidth=$PAGE_WIDTH pageHeight=$PAGE_HEIGHT"

# ── 1. Scannen ───────────────────────────────────────────────
scanimage \
    --device "$SCANBD_DEVICE" \
    --format=tiff \
    --resolution $RESOLUTION \
    --mode "$COLOR_MODE" \
    --source "$SCAN_MODE" \
    --page-width $PAGE_WIDTH \
    --page-height $PAGE_HEIGHT \
    -x $PAGE_WIDTH \
    -y $PAGE_HEIGHT \
    --swskip $SWSKIP \
    --swdeskew=yes \
    --batch="$TMPDIR/scan_${TIMESTAMP}_%d.tiff"

if [ $? -ne 0 ]; then
    echo "Fehler beim Scannen"
    exit 1
fi
echo "Scan abgeschlossen"

# ── 2. Pro Seite: Deskew + Orientierung korrigieren + OCR ────
PAGE_PDFS=""
for TIFF in "$TMPDIR/scan_${TIMESTAMP}_"*.tiff; do
    PAGE=$(basename $TIFF .tiff)
    PDF_PAGE="$TMPDIR/$PAGE"

    # Orientierung erkennen
    ROTATE=$(tesseract $TIFF stdout --psm 0 2>&1 | grep "Rotate" | head -1 | awk '{print $2}')
    echo "Seite $PAGE – Rotationswinkel: $ROTATE"

    if [ ! -z "$ROTATE" ] && [ "$ROTATE" != "0" ]; then
        echo "Drehe $PAGE um $ROTATE Grad..."
        convert $TIFF -rotate $ROTATE $TIFF
    fi

    # OCR + PDF
    tesseract $TIFF $PDF_PAGE -l deu pdf
    if [ $? -ne 0 ]; then
        echo "Fehler bei OCR auf $PAGE"
        exit 1
    fi

    PAGE_PDFS="$PAGE_PDFS $PDF_PAGE.pdf"
    rm -f $TIFF
done
echo "OCR abgeschlossen"

# ── 3. PDFs zusammenfügen ────────────────────────────────────
pdfunite $PAGE_PDFS $PDF_FINAL.pdf

if [ $? -ne 0 ]; then
    echo "Fehler beim Zusammenfügen der PDFs"
    exit 1
fi
rm -f $PAGE_PDFS
echo "PDFs zusammengefügt: $PDF_FINAL.pdf"

# ── 4. An SDMS Backend senden ────────────────────────────────
curl -s -X POST "$BACKEND" \
    -F "file=@$PDF_FINAL.pdf" \
    -F "comment=" \
    -F "tagIds=" \
    -F "dateDocument=$(date +%Y-%m-%d)"

if [ $? -ne 0 ]; then
    echo "Fehler beim Senden ans Backend"
    exit 1
fi
curl -s -X POST http://localhost:8080/v1/scan/done
echo "Dokument erfolgreich hochgeladen: $(basename $PDF_FINAL.pdf)"

# ── 5. Aufräumen ─────────────────────────────────────────────
rm -f $PDF_FINAL.pdf

echo "SDMS Scan abgeschlossen"
